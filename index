<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>E-Bike Engineering Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg: #0d0f14;
  --bg2: #151820;
  --bg3: #1c2030;
  --bg4: #232840;
  --border: #2a3050;
  --text: #e8eaf6;
  --text2: #8892b0;
  --accent: #4fc3f7;
  --accent2: #81c784;
  --accent3: #ffb74d;
  --accent4: #f06292;
  --warn: #ff7043;
  --good: #66bb6a;
  --bad: #ef5350;
  --purple: #ce93d8;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px;min-height:100vh}
h1{font-size:22px;font-weight:600;color:var(--accent)}
h2{font-size:16px;font-weight:600;color:var(--accent);margin-bottom:12px}
h3{font-size:14px;font-weight:600;color:var(--text);margin-bottom:8px}

/* Header */
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{width:36px;height:36px;background:linear-gradient(135deg,#4fc3f7,#1565c0);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.header-sub{font-size:12px;color:var(--text2);margin-top:2px}

/* Tabs */
.tabs{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;display:flex;gap:4px;overflow-x:auto}
.tab{padding:12px 18px;cursor:pointer;border-bottom:2px solid transparent;color:var(--text2);font-size:13px;white-space:nowrap;transition:all .2s;display:flex;align-items:center;gap:6px}
.tab:hover{color:var(--text);background:var(--bg3)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);background:transparent}
.tab-icon{font-size:15px}

/* Panels */
.panels{padding:20px 24px;max-width:1400px;margin:0 auto}
.panel{display:none}
.panel.active{display:block}

/* Search / filter bar */
.filter-bar{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.filter-bar input,.filter-bar select{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:6px;font-size:13px;outline:none}
.filter-bar input:focus,.filter-bar select:focus{border-color:var(--accent)}
.filter-bar input{flex:1;min-width:180px}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.badge-blue{background:#1565c040;color:var(--accent)}
.badge-green{background:#2e7d3240;color:var(--accent2)}
.badge-amber{background:#e65100, 40%;color:var(--accent3)}
.badge-orange{background:#bf360c40;color:var(--warn)}
.badge-purple{background:#6a1b9a40;color:var(--purple)}
.badge-red{background:#b71c1c40;color:var(--bad)}

/* Tables */
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{background:var(--bg3);padding:10px 12px;text-align:left;color:var(--text2);font-weight:600;border-bottom:1px solid var(--border);white-space:nowrap}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s}
tbody tr:hover{background:var(--bg3)}
tbody tr:last-child{border-bottom:none}
tbody td{padding:9px 12px;color:var(--text);vertical-align:middle}
.num{text-align:right;font-family:monospace;color:var(--accent)}

/* Cards grid */
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;margin-bottom:20px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:16px;transition:border-color .2s}
.card:hover{border-color:var(--accent)}
.card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.card-title{font-weight:600;color:var(--text);font-size:14px}
.card-brand{font-size:11px;color:var(--text2);margin-top:2px}
.card-stats{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px}
.stat{background:var(--bg3);border-radius:6px;padding:6px 8px}
.stat-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}
.stat-val{font-size:14px;font-weight:600;color:var(--accent);margin-top:2px}

/* Build configurator */
.build-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:700px){.build-grid{grid-template-columns:1fr}}
.build-section{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:16px}
.build-select{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:9px 12px;border-radius:6px;font-size:13px;margin-top:6px;outline:none}
.build-select:focus{border-color:var(--accent)}
.results-panel{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:20px;margin-top:20px}
.result-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-top:14px}
.result-card{background:var(--bg3);border-radius:8px;padding:12px;text-align:center}
.result-num{font-size:26px;font-weight:700;color:var(--accent);margin:4px 0}
.result-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}

.warning-box{background:#b71c1c20;border:1px solid var(--bad);border-radius:8px;padding:12px;margin-top:12px;color:var(--bad);font-size:13px}
.ok-box{background:#1b5e2020;border:1px solid var(--good);border-radius:8px;padding:12px;margin-top:12px;color:var(--good);font-size:13px}

/* Comparison */
.compare-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.compare-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:16px}
.compare-card.winner{border-color:var(--accent2)}
.compare-bar-wrap{margin:6px 0}
.compare-bar-label{display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-bottom:3px}
.compare-bar{height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.compare-bar-fill{height:100%;border-radius:3px;transition:width .4s}

/* Charts panel */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:700px){.charts-grid{grid-template-columns:1fr}}
.chart-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:16px}
.chart-card canvas{max-height:260px}
.chart-controls{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.chart-controls select,.chart-controls input{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:6px 10px;border-radius:6px;font-size:12px;outline:none}

/* Tooltip */
.tooltip{position:relative;display:inline-block;cursor:help;border-bottom:1px dashed var(--text2)}
.tooltip:hover .tip{visibility:visible;opacity:1}
.tip{visibility:hidden;opacity:0;background:var(--bg4);color:var(--text);border:1px solid var(--border);border-radius:6px;padding:8px 10px;font-size:12px;width:200px;position:absolute;bottom:120%;left:50%;transform:translateX(-50%);z-index:200;transition:opacity .2s;pointer-events:none;line-height:1.5}

/* Btn */
.btn{background:var(--accent);color:#000;border:none;padding:9px 18px;border-radius:6px;cursor:pointer;font-weight:600;font-size:13px;transition:opacity .2s}
.btn:hover{opacity:.85}
.btn-outline{background:transparent;color:var(--accent);border:1px solid var(--accent);padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px;transition:all .2s}
.btn-outline:hover{background:var(--accent);color:#000}
.btn-sm{padding:5px 12px;font-size:12px}

/* Range estimator */
.range-controls{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
@media(max-width:600px){.range-controls{grid-template-columns:1fr}}
.slider-wrap{background:var(--bg3);border-radius:8px;padding:12px}
.slider-wrap label{font-size:12px;color:var(--text2);display:flex;justify-content:space-between}
.slider-wrap input[type=range]{width:100%;margin-top:8px;accent-color:var(--accent)}
.slider-val{color:var(--accent);font-weight:600}

/* Export */
.export-area{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px;margin-top:14px;font-family:monospace;font-size:12px;color:var(--text2);white-space:pre-wrap;max-height:300px;overflow-y:auto}

/* Scrollbar */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:#3a4060}

.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600;margin:1px}
.pill-mid{background:#1565c040;color:var(--accent)}
.pill-hub{background:#6a1b9a40;color:var(--purple)}
.pill-torque{background:#2e7d3240;color:var(--accent2)}
.pill-cadence{background:#e65100, 40%;color:var(--accent3);background:#7b3f0040}
.pill-cargo{background:#37474f40;color:#90a4ae}
.pill-mtb{background:#1b5e2040;color:#a5d6a7}
.pill-commuter{background:#0d47a140;color:#90caf9}
.pill-speed{background:#880e4f40;color:#f48fb1}

.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:gap}
.count-badge{background:var(--bg4);border:1px solid var(--border);border-radius:20px;padding:3px 12px;font-size:12px;color:var(--text2)}
</style>
</head>
<body>

<div class="header">
  <div class="logo">
    <div class="logo-icon">⚡</div>
    <div>
      <div style="font-size:18px;font-weight:700;color:var(--accent)">E-Bike Engineering Dashboard</div>
      <div class="header-sub">Professional Motor · Controller · Battery Database & Simulation</div>
    </div>
  </div>
  <div style="margin-left:auto;font-size:12px;color:var(--text2)">v2.0 · Offline Ready</div>
</div>

<div class="tabs">
  <div class="tab active" onclick="showTab('motors')"><span class="tab-icon">🔋</span>Motors</div>
  <div class="tab" onclick="showTab('controllers')"><span class="tab-icon">⚙️</span>Controllers</div>
  <div class="tab" onclick="showTab('batteries')"><span class="tab-icon">🔌</span>Batteries</div>
  <div class="tab" onclick="showTab('build')"><span class="tab-icon">🧰</span>Build Configurator</div>
  <div class="tab" onclick="showTab('compare')"><span class="tab-icon">⚡</span>Comparison Engine</div>
  <div class="tab" onclick="showTab('graphs')"><span class="tab-icon">📊</span>Graphs</div>
</div>

<div class="panels">

<!-- MOTORS PANEL -->
<div id="panel-motors" class="panel active">
  <div class="section-header">
    <h2>Motor Database</h2>
    <span class="count-badge" id="motor-count"></span>
  </div>
  <div class="filter-bar">
    <input type="text" id="motor-search" placeholder="Search motors…" oninput="filterMotors()">
    <select onchange="filterMotors()" id="motor-brand">
      <option value="">All Brands</option>
      <option>Bafang</option><option>Bosch</option><option>Shimano</option><option>Yamaha</option>
      <option>Brose</option><option>Panasonic</option><option>Specialized</option><option>CYC Motors</option>
      <option>QS Motor</option><option>MXUS</option><option>Crystalyte</option><option>Nine Continent</option>
      <option>Golden Motor</option>
    </select>
    <select onchange="filterMotors()" id="motor-type">
      <option value="">All Types</option>
      <option>Mid-Drive</option><option>Hub Motor</option>
    </select>
    <select onchange="filterMotors()" id="motor-use">
      <option value="">All Use Cases</option>
      <option>MTB</option><option>Commuter</option><option>Cargo</option><option>Speed</option><option>Universal</option>
    </select>
  </div>
  <div class="table-wrap">
    <table id="motor-table">
      <thead>
        <tr>
          <th>Motor</th><th>Brand</th><th>Type</th>
          <th>Rated W</th><th>Peak W</th><th>Torque Nm</th>
          <th>Voltage</th><th>Sensor</th><th>Efficiency</th><th>Use Case</th>
        </tr>
      </thead>
      <tbody id="motor-tbody"></tbody>
    </table>
  </div>
</div>

<!-- CONTROLLERS PANEL -->
<div id="panel-controllers" class="panel">
  <div class="section-header">
    <h2>Controller Database</h2>
    <span class="count-badge" id="ctrl-count"></span>
  </div>
  <div class="filter-bar">
    <input type="text" id="ctrl-search" placeholder="Search controllers…" oninput="filterControllers()">
    <select onchange="filterControllers()" id="ctrl-brand">
      <option value="">All Brands</option>
      <option>KT</option><option>Bafang</option><option>ASI</option><option>Kelly</option>
      <option>Fardriver</option><option>Sabvoton</option><option>VESC</option>
    </select>
    <select onchange="filterControllers()" id="ctrl-proto">
      <option value="">All Protocols</option>
      <option>UART</option><option>CAN</option><option>Analog</option><option>USB</option>
    </select>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Model</th><th>Brand</th><th>Voltage Range</th><th>Max Current (A)</th>
          <th>Protocol</th><th>Programmable</th><th>Sine Wave</th><th>Use Case</th>
        </tr>
      </thead>
      <tbody id="ctrl-tbody"></tbody>
    </table>
  </div>
</div>

<!-- BATTERIES PANEL -->
<div id="panel-batteries" class="panel">
  <div class="section-header">
    <h2>Battery Database & Range Calculator</h2>
  </div>
  <div class="filter-bar">
    <input type="text" id="batt-search" placeholder="Search batteries…" oninput="filterBatteries()">
    <select onchange="filterBatteries()" id="batt-volt">
      <option value="">All Voltages</option>
      <option>36V</option><option>48V</option><option>52V</option><option>60V</option><option>72V</option>
    </select>
    <select onchange="filterBatteries()" id="batt-cell">
      <option value="">All Cell Types</option>
      <option>18650</option><option>21700</option>
    </select>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Pack</th><th>Voltage</th><th>Capacity Ah</th><th>Energy Wh</th>
          <th>Cell Type</th><th>Cont. Discharge (A)</th><th>Peak (A)</th>
          <th>Range Urban (km)</th><th>Range Off-Road (km)</th>
        </tr>
      </thead>
      <tbody id="batt-tbody"></tbody>
    </table>
  </div>

  <div style="margin-top:24px">
    <h2>Custom Range Estimator</h2>
    <div class="range-controls">
      <div class="slider-wrap">
        <label>Battery Capacity (Wh) <span class="slider-val" id="wh-val">500 Wh</span></label>
        <input type="range" min="100" max="2000" step="10" value="500" oninput="updateRange()" id="wh-slider">
      </div>
      <div class="slider-wrap">
        <label>Motor Power (W) <span class="slider-val" id="mw-val">500 W</span></label>
        <input type="range" min="100" max="3000" step="50" value="500" oninput="updateRange()" id="mw-slider">
      </div>
      <div class="slider-wrap">
        <label>Rider Weight (kg) <span class="slider-val" id="rw-val">80 kg</span></label>
        <input type="range" min="40" max="160" step="1" value="80" oninput="updateRange()" id="rw-slider">
      </div>
      <div class="slider-wrap">
        <label>Average Speed (km/h) <span class="slider-val" id="spd-val">25 km/h</span></label>
        <input type="range" min="10" max="60" step="1" value="25" oninput="updateRange()" id="spd-slider">
      </div>
    </div>
    <div class="result-grid" id="range-results"></div>
  </div>
</div>

<!-- BUILD CONFIGURATOR PANEL -->
<div id="panel-build" class="panel">
  <h2>Build Configurator</h2>
  <p style="color:var(--text2);margin-bottom:16px;font-size:13px">Select your components — the system checks compatibility and calculates performance.</p>

  <div class="build-grid">
    <div class="build-section">
      <h3>🔋 Motor</h3>
      <select class="build-select" id="build-motor" onchange="runBuild()">
        <option value="">— Select Motor —</option>
      </select>
    </div>
    <div class="build-section">
      <h3>⚙️ Controller</h3>
      <select class="build-select" id="build-ctrl" onchange="runBuild()">
        <option value="">— Select Controller —</option>
      </select>
    </div>
    <div class="build-section">
      <h3>🔌 Battery</h3>
      <select class="build-select" id="build-batt" onchange="runBuild()">
        <option value="">— Select Battery —</option>
      </select>
    </div>
    <div class="build-section">
      <h3>🚲 Bike Type</h3>
      <select class="build-select" id="build-bike" onchange="runBuild()">
        <option value="commuter">Commuter / Urban</option>
        <option value="mtb">Mountain Bike (MTB)</option>
        <option value="cargo">Cargo Bike</option>
        <option value="speed">Speed / Race</option>
      </select>
    </div>
  </div>

  <div class="results-panel" id="build-results">
    <h3>Build Results</h3>
    <p style="color:var(--text2);font-size:13px;margin-top:8px">Select all components above to see compatibility analysis and performance estimates.</p>
  </div>

  <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
    <button class="btn" onclick="exportBuild()">Export Build Summary</button>
    <button class="btn-outline" onclick="resetBuild()">Reset</button>
  </div>
  <div class="export-area" id="build-export" style="display:none"></div>
</div>

<!-- COMPARISON PANEL -->
<div id="panel-compare" class="panel">
  <h2>Comparison Engine</h2>

  <div style="margin-bottom:20px">
    <h3>Mid-Drive vs Hub Motor — Efficiency & Performance</h3>
    <div class="compare-grid" id="drive-compare"></div>
  </div>

  <div style="margin-top:28px;margin-bottom:20px">
    <h3>Geared Hub vs Direct Drive Hub</h3>
    <div class="compare-grid" id="hub-compare"></div>
  </div>

  <div style="margin-top:28px">
    <h3>Top Torque vs High Efficiency Setups</h3>
    <div class="compare-grid" id="torque-compare"></div>
  </div>
</div>

<!-- GRAPHS PANEL -->
<div id="panel-graphs" class="panel">
  <h2>Interactive Performance Graphs</h2>
  <div class="charts-grid">
    <div class="chart-card">
      <h3>Battery Capacity vs Range</h3>
      <div class="chart-controls">
        <select id="range-terrain" onchange="updateAllCharts()">
          <option value="urban">Urban</option>
          <option value="offroad">Off-Road</option>
          <option value="mixed">Mixed</option>
        </select>
        <select id="range-power" onchange="updateAllCharts()">
          <option value="250">250W Motor</option>
          <option value="500">500W Motor</option>
          <option value="750" selected>750W Motor</option>
          <option value="1000">1000W Motor</option>
        </select>
      </div>
      <canvas id="chart-range"></canvas>
    </div>

    <div class="chart-card">
      <h3>Motor Power vs Torque Curves</h3>
      <div class="chart-controls">
        <select id="torque-motor" onchange="updateAllCharts()">
          <option value="bbshd">Bafang BBSHD</option>
          <option value="cx">Bosch CX Gen5</option>
          <option value="ep8">Shimano EP8</option>
          <option value="qs205">QS Motor 205</option>
        </select>
      </div>
      <canvas id="chart-torque"></canvas>
    </div>

    <div class="chart-card">
      <h3>Efficiency Comparison</h3>
      <canvas id="chart-efficiency"></canvas>
    </div>

    <div class="chart-card">
      <h3>Voltage vs Top Speed</h3>
      <div class="chart-controls">
        <select id="speed-motor" onchange="updateAllCharts()">
          <option value="48">48V Base</option>
          <option value="52">52V Base</option>
          <option value="60">60V Base</option>
          <option value="72">72V Base</option>
        </select>
      </div>
      <canvas id="chart-speed"></canvas>
    </div>

    <div class="chart-card" style="grid-column:span 2">
      <h3>Range Estimator — Wh vs Conditions</h3>
      <div class="chart-controls">
        <label style="color:var(--text2);font-size:12px">Weight (kg): <input type="range" min="60" max="150" value="80" id="graph-weight" oninput="updateAllCharts();document.getElementById('gwlbl').textContent=this.value+'kg'" style="width:100px;accent-color:var(--accent)"> <span id="gwlbl">80kg</span></label>
      </div>
      <canvas id="chart-range2" style="max-height:220px"></canvas>
    </div>
  </div>
</div>

</div>

<script>
// ==================== DATA ====================

const MOTORS = [
  // Bafang BBS Series
  {name:'BBS01B',brand:'Bafang',series:'BBS',type:'Mid-Drive',rated:250,peak:350,torque:80,voltage:36,sensor:'Cadence',efficiency:85,use:'Commuter'},
  {name:'BBS02B',brand:'Bafang',series:'BBS',type:'Mid-Drive',rated:500,peak:750,torque:120,voltage:48,sensor:'Cadence',efficiency:86,use:'Commuter'},
  {name:'BBSHD',brand:'Bafang',series:'BBS',type:'Mid-Drive',rated:1000,peak:1500,torque:160,voltage:48,sensor:'Cadence+Torque',efficiency:87,use:'MTB'},
  // Bafang M Series
  {name:'M200',brand:'Bafang',series:'M Series',type:'Mid-Drive',rated:250,peak:400,torque:60,voltage:36,sensor:'Torque',efficiency:88,use:'Commuter'},
  {name:'M300',brand:'Bafang',series:'M Series',type:'Mid-Drive',rated:250,peak:450,torque:65,voltage:36,sensor:'Torque',efficiency:88,use:'Commuter'},
