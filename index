// ==================== BUILD CONFIGURATOR ====================
function populateBuildSelects(){
  const ms = document.getElementById('build-motor');
  const cs = document.getElementById('build-ctrl');
  const bs = document.getElementById('build-batt');
  MOTORS.forEach((m,i)=>ms.add(new Option(`${m.brand} ${m.name} (${m.rated}W, ${m.voltage}V)`,i)));
  CONTROLLERS.forEach((c,i)=>cs.add(new Option(`${c.brand} ${c.name} (${c.voltage}, ${c.current}A)`,i)));
  BATTERIES.forEach((b,i)=>bs.add(new Option(`${b.name} (${b.wh}Wh)`,i)));
}

function runBuild(){
  const mi = document.getElementById('build-motor').value;
  const ci = document.getElementById('build-ctrl').value;
  const bi = document.getElementById('build-batt').value;
  const bike = document.getElementById('build-bike').value;
  if(mi===''||ci===''||bi===''){return;}

  const m = MOTORS[+mi];
  const c = CONTROLLERS[+ci];
  const b = BATTERIES[+bi];

  const warnings = [];
  const oks = [];

  // Voltage check
  const cVoltMin = parseInt(c.voltage.split('-')[0] || c.voltage);
  const cVoltMax = parseInt(c.voltage.split('-').pop());
  if(m.voltage < cVoltMin || m.voltage > cVoltMax){
    warnings.push(`⚠️ Motor voltage (${m.voltage}V) is outside controller voltage range (${c.voltage})`);
  } else {
    oks.push(`✓ Voltage compatible: motor ${m.voltage}V within controller range (${c.voltage})`);
  }
  if(b.voltage !== m.voltage){
    warnings.push(`⚠️ Battery voltage (${b.voltage}V) doesn't match motor voltage (${m.voltage}V)`);
  } else {
    oks.push(`✓ Battery and motor voltages match (${b.voltage}V)`);
  }

  const peakCurrent = m.peak / b.voltage;
  if(peakCurrent > c.current){
    warnings.push(`⚠️ Motor peak current draw (${Math.round(peakCurrent)}A) exceeds controller limit (${c.current}A)`);
  } else {
    oks.push(`✓ Peak current OK: motor draws ~${Math.round(peakCurrent)}A, controller rated ${c.current}A`);
  }
  if(peakCurrent > b.peakA){
    warnings.push(`⚠️ Motor peak draw (${Math.round(peakCurrent)}A) exceeds battery peak discharge (${b.peakA}A)`);
  } else {
    oks.push(`✓ Battery peak discharge adequate (${b.peakA}A peak available)`);
  }

  // Performance estimates
  const effMulti = {urban:1.0,mtb:0.85,cargo:0.80,speed:0.90}[bike];
  const rangeEst = Math.round(calcRange(b.wh,'urban') * effMulti);
  const torqueOut = Math.round(m.torque * (m.type==='Mid-Drive'?1.0:0.85));
  const topSpeed = Math.round((m.voltage * 0.95 * (m.type==='Mid-Drive'?0.55:0.48)) + (bike==='speed'?5:0));
  const effScore = Math.round((m.efficiency * 0.5 + (warnings.length===0?95:75) * 0.3 + (m.sensor.includes('Torque')?90:70)*0.2));

  const bikeWeights = {urban:'+8kg bike',mtb:'+12kg bike',cargo:'+20kg bike',speed:'+7kg bike'};

  const r = document.getElementById('build-results');
  r.innerHTML = `
    <h3>Build Analysis — ${m.brand} ${m.name} · ${c.brand} ${c.name} · ${b.name}</h3>
    ${warnings.map(w=>`<div class="warning-box">${w}</div>`).join('')}
    ${oks.map(o=>`<div class="ok-box">${o}</div>`).join('')}
    <div class="result-grid" style="margin-top:16px">
      <div class="result-card">
        <div class="result-label">Est. Top Speed</div>
        <div class="result-num" style="color:var(--accent)">${topSpeed} km/h</div>
      </div>
      <div class="result-card">
        <div class="result-label">Range (${bike})</div>
        <div class="result-num" style="color:var(--accent2)">${rangeEst} km</div>
      </div>
      <div class="result-card">
        <div class="result-label">Torque Output</div>
        <div class="result-num" style="color:var(--accent3)">${torqueOut} Nm</div>
      </div>
      <div class="result-card">
        <div class="result-label">Efficiency Score</div>
        <div class="result-num" style="color:${effScore>=85?'var(--good)':effScore>=70?'var(--accent3)':'var(--bad)'}">${effScore}/100</div>
      </div>
      <div class="result-card">
        <div class="result-label">Total Energy</div>
        <div class="result-num" style="color:var(--purple)">${b.wh} Wh</div>
      </div>
      <div class="result-card">
        <div class="result-label">Peak Power</div>
        <div class="result-num" style="color:var(--warn)">${m.peak} W</div>
      </div>
    </div>
    <p style="color:var(--text2);font-size:12px;margin-top:12px">Weight reference: ${bikeWeights[bike]} + rider + battery ${Math.round(b.wh/100)}kg est. | Controller: ${c.prog} programmability</p>
  `;
}

function exportBuild(){
  const mi = document.getElementById('build-motor').value;
  const ci = document.getElementById('build-ctrl').value;
  const bi = document.getElementById('build-batt').value;
  const bike = document.getElementById('build-bike').value;
  if(mi===''||ci===''||bi===''){alert('Select all components first.');return;}
  const m=MOTORS[+mi],c=CONTROLLERS[+ci],b=BATTERIES[+bi];
  const txt = `E-BIKE BUILD SUMMARY\n${'='.repeat(50)}\nGenerated: ${new Date().toLocaleString()}\n\nMOTOR\n  Model: ${m.brand} ${m.name}\n  Series: ${m.series}\n  Type: ${m.type}\n  Rated Power: ${m.rated}W\n  Peak Power: ${m.peak}W\n  Torque: ${m.torque} Nm\n  Voltage: ${m.voltage}V\n  Sensor: ${m.sensor}\n  Efficiency: ${m.efficiency}%\n\nCONTROLLER\n  Model: ${c.brand} ${c.name}\n  Voltage: ${c.voltage}\n  Max Current: ${c.current}A\n  Protocol: ${c.protocol}\n  Programmability: ${c.prog}\n\nBATTERY\n  Pack: ${b.name}\n  Voltage: ${b.voltage}V\n  Capacity: ${b.ah}Ah (${b.wh}Wh)\n  Cell Type: ${b.cell}\n  Cont. Discharge: ${b.contA}A\n  Peak Discharge: ${b.peakA}A\n\nBIKE TYPE: ${bike.toUpperCase()}\n\n${'='.repeat(50)}\nE-Bike Engineering Dashboard`;
  const el = document.getElementById('build-export');
  el.style.display='block';
  el.textContent=txt;
}

function resetBuild(){
  document.getElementById('build-motor').value='';
  document.getElementById('build-ctrl').value='';
  document.getElementById('build-batt').value='';
  document.getElementById('build-results').innerHTML='<h3>Build Results</h3><p style="color:var(--text2);font-size:13px;margin-top:8px">Select all components above to see compatibility analysis.</p>';
  document.getElementById('build-export').style.display='none';
}

