// ==================== CHARTS ====================
let charts = {};

function getChartDefaults(){
  return {
    plugins:{legend:{labels:{color:'#8892b0',font:{size:12}}},tooltip:{backgroundColor:'#1c2030',titleColor:'#e8eaf6',bodyColor:'#8892b0',borderColor:'#2a3050',borderWidth:1}},
    scales:{x:{ticks:{color:'#8892b0'},grid:{color:'#2a305040'}},y:{ticks:{color:'#8892b0'},grid:{color:'#2a305040'}}}
  };
}

function initCharts(){
  Chart.defaults.color='#8892b0';

  // Chart 1: Battery capacity vs range
  charts.range = new Chart(document.getElementById('chart-range'),{
    type:'line',
    data:{labels:[],datasets:[]},
    options:{...getChartDefaults(),responsive:true,maintainAspectRatio:true}
  });

  // Chart 2: Torque curve
  charts.torque = new Chart(document.getElementById('chart-torque'),{
    type:'line',
    data:{labels:[],datasets:[]},
    options:{...getChartDefaults(),responsive:true,maintainAspectRatio:true}
  });

  // Chart 3: Efficiency comparison
  charts.efficiency = new Chart(document.getElementById('chart-efficiency'),{
    type:'bar',
    data:{labels:[],datasets:[]},
    options:{...getChartDefaults(),responsive:true,maintainAspectRatio:true,indexAxis:'y'}
  });

  // Chart 4: Voltage vs Speed
  charts.speed = new Chart(document.getElementById('chart-speed'),{
    type:'line',
    data:{labels:[],datasets:[]},
    options:{...getChartDefaults(),responsive:true,maintainAspectRatio:true}
  });

  // Chart 5: Range estimator multi-condition
  charts.range2 = new Chart(document.getElementById('chart-range2'),{
    type:'bar',
    data:{labels:[],datasets:[]},
    options:{...getChartDefaults(),responsive:true,maintainAspectRatio:true}
  });

  updateAllCharts();
}

function updateAllCharts(){
  updateRangeChart();
  updateTorqueChart();
  updateEfficiencyChart();
  updateSpeedChart();
  updateRange2Chart();
}

function updateRangeChart(){
  const terrain = document.getElementById('range-terrain').value;
  const power = +document.getElementById('range-power').value;
  const whs = [200,300,400,500,600,750,1000,1200,1500,2000];
  const factors = {urban:1.0,offroad:0.65,mixed:0.80};
  const f = factors[terrain];
  const powerFactor = power<=250?1.1:power<=500?1.0:power<=750?0.9:0.8;

  charts.range.data.labels = whs.map(w=>w+'Wh');
  charts.range.data.datasets = [{
    label:`Range (${terrain}) - ${power}W`,
    data: whs.map(w=>Math.round(w/((power*0.08+8))*f*powerFactor*10)/10),
    borderColor:'#4fc3f7',backgroundColor:'#4fc3f720',fill:true,tension:0.4,pointRadius:4
  }];
  charts.range.update();
}

function updateTorqueChart(){
  const motor = document.getElementById('torque-motor').value;
  const speeds = [0,5,10,15,20,25,30,35,40,45,50];
  const curves = {
    bbshd:{label:'Bafang BBSHD',peak:160,color:'#4fc3f7',
      data:speeds.map(s=>s<5?160:s<15?160-s*2:s<30?130-s:Math.max(0,100-s*1.5))},
    cx:{label:'Bosch CX Gen5',peak:85,color:'#81c784',
      data:speeds.map(s=>s<5?85:s<20?85-s*1.5:Math.max(0,55-s*1.2))},
    ep8:{label:'Shimano EP8',peak:85,color:'#ffb74d',
      data:speeds.map(s=>s<5?85:s<18?85-s*1.8:Math.max(0,52-s*1.1))},
    qs205:{label:'QS 205 2000W Hub',peak:100,color:'#f06292',
      data:speeds.map(s=>s<10?100:s<25?100-s*1.2:Math.max(0,70-s*0.9))}
  };
  const c = curves[motor];
  charts.torque.data.labels = speeds.map(s=>s+'km/h');
  charts.torque.data.datasets=[{
    label:c.label+' Torque (Nm)',data:c.data,
    borderColor:c.color,backgroundColor:c.color+'20',fill:true,tension:0.4,pointRadius:3
  }];
  charts.torque.update();
}

function updateEfficiencyChart(){
  const motors = [
    {name:'Bosch CX Gen5',eff:91},{name:'Shimano EP8',eff:90},{name:'Brose Drive S',eff:90},
    {name:'Yamaha PW-X3',eff:90},{name:'Bafang M620',eff:91},{name:'QS 273 8kW',eff:88},
    {name:'Bafang BBSHD',eff:87},{name:'QS 205 3kW',eff:86},{name:'MXUS 3K Turbo',eff:86},
    {name:'Crystalyte H4080',eff:84},{name:'MXUS XF40',eff:84},{name:'Bafang RMG063',eff:84},
    {name:'Nine Cont 3007',eff:83},{name:'Bafang SWXK',eff:83},
  ];
  const colors = motors.map(m=>m.eff>=90?'#66bb6a':m.eff>=87?'#4fc3f7':m.eff>=84?'#ffb74d':'#ef5350');
  charts.efficiency.data.labels = motors.map(m=>m.name);
  charts.efficiency.data.datasets=[{
    label:'Efficiency %',data:motors.map(m=>m.eff),
    backgroundColor:colors,borderRadius:4
  }];
  charts.efficiency.options.scales.x.min = 78;
  charts.efficiency.update();
}

function updateSpeedChart(){
  const baseV = +document.getElementById('speed-motor').value;
  const voltages = [baseV, baseV+4, baseV+8, baseV+12, baseV+24].filter(v=>v<=120);
  charts.speed.data.labels = voltages.map(v=>v+'V');
  charts.speed.data.datasets = [
    {label:'Mid-Drive (estimated)',data:voltages.map(v=>Math.round(v*0.56+2)),borderColor:'#4fc3f7',backgroundColor:'#4fc3f720',fill:false,tension:0.3,pointRadius:5},
    {label:'Hub Motor (estimated)',data:voltages.map(v=>Math.round(v*0.49+1)),borderColor:'#81c784',backgroundColor:'#81c78420',fill:false,tension:0.3,pointRadius:5},
  ];
  charts.speed.update();
}

function updateRange2Chart(){
  const weight = +document.getElementById('graph-weight').value;
  const packs = ['36V 10Ah\n360Wh','48V 13Ah\n624Wh','52V 17Ah\n884Wh','60V 20Ah\n1200Wh','72V 30Ah\n2160Wh'];
  const whs = [360,624,884,1200,2160];
  const urbanRanges = whs.map(w=>Math.round(w/(weight*0.04+5)*1.0));
  const mixedRanges = whs.map(w=>Math.round(w/(weight*0.04+5)*0.80));
  const offroadRanges = whs.map(w=>Math.round(w/(weight*0.04+5)*0.60));
  charts.range2.data.labels = packs;
  charts.range2.data.datasets=[
    {label:'Urban',data:urbanRanges,backgroundColor:'#4fc3f7'},
    {label:'Mixed',data:mixedRanges,backgroundColor:'#81c784'},
    {label:'Off-Road',data:offroadRanges,backgroundColor:'#ffb74d'},
  ];
  charts.range2.update();
}

// ==================== TABS ====================
function showTab(name){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  event.currentTarget.classList.add('active');
  if(name==='graphs' && !charts.range) setTimeout(initCharts, 100);
}

// ==================== INIT ====================
window.addEventListener('DOMContentLoaded',()=>{
  renderMotors(MOTORS);
  renderControllers(CONTROLLERS);
  renderBatteries(BATTERIES);
  populateBuildSelects();
  renderComparisons();
  updateRange();
});
</script>
