// ==================== RANGE CALCULATOR ====================
function updateRange(){
  const wh = +document.getElementById('wh-slider').value;
  const mw = +document.getElementById('mw-slider').value;
  const rw = +document.getElementById('rw-slider').value;
  const spd = +document.getElementById('spd-slider').value;
  document.getElementById('wh-val').textContent = wh + ' Wh';
  document.getElementById('mw-val').textContent = mw + ' W';
  document.getElementById('rw-val').textContent = rw + ' kg';
  document.getElementById('spd-val').textContent = spd + ' km/h';

  const rollingResist = 0.006;
  const gravity = 9.81;
  const dragCoeff = 0.4;
  const frontalArea = 0.5;
  const airDensity = 1.225;
  const effFactor = mw > 1000 ? 0.82 : mw > 500 ? 0.85 : 0.88;

  const spdMs = spd / 3.6;
  const rollingW = rollingResist * (rw + 20) * gravity * spdMs;
  const aeroDragW = 0.5 * airDensity * dragCoeff * frontalArea * spdMs ** 3;
  const totalW = rollingW + aeroDragW + 30;
  const whPerKm = (totalW / spd) / effFactor;
  const rangeUrban = Math.round(wh / whPerKm * 0.95);
  const rangeMix = Math.round(wh / whPerKm * 0.80);
  const rangeOffroad = Math.round(wh / whPerKm * 0.60);
  const timeHours = Math.round(wh / totalW * 10) / 10;

  document.getElementById('range-results').innerHTML = `
    <div class="result-card">
      <div class="result-label">Urban Range</div>
      <div class="result-num" style="color:var(--accent)">${rangeUrban} km</div>
    </div>
    <div class="result-card">
      <div class="result-label">Mixed Range</div>
      <div class="result-num" style="color:var(--accent2)">${rangeMix} km</div>
    </div>
    <div class="result-card">
      <div class="result-label">Off-Road Range</div>
      <div class="result-num" style="color:var(--accent3)">${rangeOffroad} km</div>
    </div>
    <div class="result-card">
      <div class="result-label">Wh/km</div>
